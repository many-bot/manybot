#!/bin/bash
set -euo pipefail
IFS=$'\n\t'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors
R="\033[0m" BOLD="\033[1m" DIM="\033[2m"
RED="\033[31m" GREEN="\033[32m" YELLOW="\033[33m"
BLUE="\033[34m" CYAN="\033[36m" MAGENTA="\033[35m"

# ── Language detection ────────────────────────────────────────────────────────
detect_lang() {
    local v
    for v in "${MANYBOT_LANG:-}" "${LANG:-}" "${LC_ALL:-}" "${LC_MESSAGES:-}"; do
        case "${v,,}" in pt*) echo "pt"; return ;; esac
    done
    echo "en"
}
LANG_CODE="$(detect_lang)"

t() {
    local key="$1"
    case "$LANG_CODE:$key" in
        pt:slogan)            echo "A crina que seu grupo precisava." ;;
        en:slogan)            echo "One bot. Many possibilities." ;;

        pt:lang_notice)       echo "Idioma: Português  |  MANYBOT_LANG=en para inglês." ;;
        en:lang_notice)       echo "Language: English  |  MANYBOT_LANG=pt for Portuguese." ;;

        pt:err_line)          echo "Falha na linha" ;;
        pt:err_exit)          echo "código de saída" ;;
        pt:err_debug)         echo "Execute com 'bash -x $0' para depurar." ;;
        en:err_line)          echo "Failure at line" ;;
        en:err_exit)          echo "exit code" ;;
        en:err_debug)         echo "Run 'bash -x $0' for a full trace." ;;

        pt:dep_missing)       echo "Dependência ausente:" ;;
        pt:dep_hint)          echo "Instale-a e tente novamente." ;;
        en:dep_missing)       echo "Required command not found:" ;;
        en:dep_hint)          echo "Please install it and retry." ;;

        pt:node_old)          echo "Node.js >= 18 obrigatório (encontrado:" ;;
        en:node_old)          echo "Node.js >= 18 required (found:" ;;

        pt:mp_up_to_date)     echo "ManyPlug já está atualizado" ;;
        pt:mp_outdated)       echo "ManyPlug desatualizado" ;;
        pt:mp_not_found)      echo "ManyPlug não encontrado" ;;
        pt:mp_prompt_update)  echo "Atualizar ManyPlug? [S/n]: " ;;
        pt:mp_prompt_install) echo "Instalar ManyPlug globalmente? [S/n]: " ;;
        pt:mp_prompt_yes)     echo "s" ;;
        pt:mp_installing)     echo "Instalando ManyPlug..." ;;
        pt:mp_fail)           echo "Falha ao instalar ManyPlug." ;;
        pt:mp_no_path)        echo "ManyPlug instalado, mas não está no PATH." ;;
        pt:mp_path_hint)      echo "Adicione o diretório global do npm ao PATH." ;;
        pt:mp_success)        echo "ManyPlug instalado." ;;
        pt:mp_skipped)        echo "ManyPlug ignorado." ;;
        en:mp_up_to_date)     echo "ManyPlug is up to date" ;;
        en:mp_outdated)       echo "ManyPlug is outdated" ;;
        en:mp_not_found)      echo "ManyPlug not found" ;;
        en:mp_prompt_update)  echo "Update ManyPlug? [Y/n]: " ;;
        en:mp_prompt_install) echo "Install ManyPlug globally? [Y/n]: " ;;
        en:mp_prompt_yes)     echo "y" ;;
        en:mp_installing)     echo "Installing ManyPlug..." ;;
        en:mp_fail)           echo "Failed to install ManyPlug." ;;
        en:mp_no_path)        echo "ManyPlug installed but not in PATH." ;;
        en:mp_path_hint)      echo "Add npm's global bin directory to your PATH." ;;
        en:mp_success)        echo "ManyPlug installed." ;;
        en:mp_skipped)        echo "ManyPlug skipped." ;;

        pt:conf_exists)       echo "manybot.conf já existe." ;;
        pt:conf_created)      echo "manybot.conf criado — edite antes de iniciar o bot." ;;
        pt:conf_missing)      echo "manybot.conf.example não encontrado — configure manualmente." ;;
        en:conf_exists)       echo "manybot.conf already exists." ;;
        en:conf_created)      echo "manybot.conf created — edit it before starting the bot." ;;
        en:conf_missing)      echo "manybot.conf.example not found — configure manually." ;;

        pt:svc_no_systemd)      echo "systemctl não encontrado — pulando." ;;
        pt:svc_root_blocked)    echo "Não execute o setup como root. Use seu usuário normal." ;;
        pt:svc_prompt)          echo "Instalar como serviço? [S = serviço de usuário / l = salvar .service local / n = não]: " ;;
        pt:svc_opt_user)        echo "u" ;;
        pt:svc_opt_local)       echo "l" ;;
        pt:svc_no_linger)       echo "loginctl enable-linger falhou — o serviço pode não iniciar sem sessão ativa." ;;
        pt:svc_user_done)       echo "Serviço de usuário instalado e iniciado." ;;
        pt:svc_user_cmds)       echo "  status: systemctl --user status manybot  |  logs: journalctl --user -u manybot -f" ;;
        pt:svc_local_done)      echo "manybot.service salvo na pasta do projeto." ;;
        pt:svc_local_hint)      echo "Para instalar manualmente: systemctl --user enable --now $SCRIPT_DIR/manybot.service" ;;
        pt:svc_skipped)         echo "Serviço ignorado." ;;
        en:svc_no_systemd)      echo "systemctl not found — skipping." ;;
        en:svc_root_blocked)    echo "Do not run setup as root. Use your normal user account." ;;
        en:svc_prompt)          echo "Install as a service? [Y = user service / l = save .service locally / n = no]: " ;;
        en:svc_opt_user)        echo "y" ;;
        en:svc_opt_local)       echo "l" ;;
        en:svc_no_linger)       echo "loginctl enable-linger failed — service may not start without an active session." ;;
        en:svc_user_done)       echo "User service installed and started." ;;
        en:svc_user_cmds)       echo "  status: systemctl --user status manybot  |  logs: journalctl --user -u manybot -f" ;;
        en:svc_local_done)      echo "manybot.service saved in the project directory." ;;
        en:svc_local_hint)      echo "To install manually: systemctl --user enable --now $SCRIPT_DIR/manybot.service" ;;
        en:svc_skipped)         echo "Service skipped." ;;

        pt:done)              echo "Pronto! Para iniciar:  node src/main.js" ;;
        en:done)              echo "Done! To start:  node src/main.js" ;;

        *) echo "$key" ;;
    esac
}

# ── Logging ───────────────────────────────────────────────────────────────────
ok()   { printf "  ${GREEN}✓${R}  %s\n"         "$*"; }
info() { printf "  ${BLUE}·${R}  ${DIM}%s${R}\n" "$*"; }
warn() { printf "  ${YELLOW}!${R}  %s\n"         "$*"; }
err()  { printf "  ${RED}✗${R}  %s\n"            "$*" >&2; }
step() { printf "\n${MAGENTA}${BOLD}%s${R}\n"    "$*"; }

on_error() {
    local code=$? line=$1
    err "$(t err_line) ${line} ($(t err_exit): ${code})"
    err "$(t err_debug)"
    exit "$code"
}
trap 'on_error $LINENO' ERR

require_cmd() {
    if ! command -v "$1" &>/dev/null; then
        err "$(t dep_missing) '$1'. $(t dep_hint)"; exit 1
    fi
}

confirm() {
    local choice
    read -r -p "       $1" choice
    choice="${choice,,}"
    local yes; yes="$(t mp_prompt_yes)"
    [[ "$choice" == "$yes" || -z "$choice" ]]
}

website="https://manybot.stxerr.dev"

printf "\n  ${BLUE}${BOLD}ManyBot${R}  ${DIM}$(t slogan)  —  $website${R}\n\n"

info "$(t lang_notice)"

# ── Prerequisites ─────────────────────────────────────────────────────────────
step "Prerequisites"
require_cmd node
require_cmd npm

NODE_VER="$(node -v)"
NODE_MAJOR="${NODE_VER#v}"; NODE_MAJOR="${NODE_MAJOR%%.*}"
if (( NODE_MAJOR < 18 )); then
    err "$(t node_old) $NODE_VER)."; exit 1
fi
ok "node $NODE_VER  ·  npm $(npm -v)"

# ── npm install ───────────────────────────────────────────────────────────────
step "npm install"
PUPPETEER_SKIP_DOWNLOAD=1 npm install
ok "npm install"

# ── Chrome (Puppeteer) ────────────────────────────────────────────────────────
step "Chrome"
npx puppeteer browsers install chrome
ok "Chrome ready"

# ── ManyPlug CLI ──────────────────────────────────────────────────────────────
step "ManyPlug"

do_install_mp() {
    info "$(t mp_installing)"
    if npm install -g @freakk.dev/manyplug; then
        if command -v manyplug &>/dev/null; then
            ok "$(t mp_success)"
        else
            err "$(t mp_no_path)"; warn "$(t mp_path_hint)"
        fi
    else
        err "$(t mp_fail)"; exit 1
    fi
}

# Returns 0 if $1 < $2 (semver); uses sort -V available in GNU coreutils
semver_lt() {
    [[ "$(printf '%s\n' "$1" "$2" | sort -V | head -1)" == "$1" && "$1" != "$2" ]]
}

if command -v manyplug &>/dev/null; then
    LOCAL="$(manyplug --version 2>/dev/null || echo "0.0.0")"
    REMOTE="$(npm view @freakk.dev/manyplug version 2>/dev/null || echo "0.0.0")"
    if semver_lt "$LOCAL" "$REMOTE"; then
        warn "$(t mp_outdated) ($LOCAL → $REMOTE)"
        confirm "$(t mp_prompt_update)" && do_install_mp || warn "$(t mp_skipped)"
    else
        ok "$(t mp_up_to_date) ($LOCAL)"
    fi
else
    warn "$(t mp_not_found)"
    confirm "$(t mp_prompt_install)" && do_install_mp || warn "$(t mp_skipped)"
fi

# ── Config file ───────────────────────────────────────────────────────────────
step "Config"
CONF="$SCRIPT_DIR/manybot.conf"
EXAMPLE="$SCRIPT_DIR/manybot.conf.example"

if   [[ -f "$CONF" ]];    then ok "$(t conf_exists)"
elif [[ -f "$EXAMPLE" ]]; then cp "$EXAMPLE" "$CONF"; warn "$(t conf_created)"
else                           warn "$(t conf_missing)"
fi

# ── systemd service ───────────────────────────────────────────────────────────
step "systemd"

# Block root — user services don't work under root and cache paths break
if [[ $EUID -eq 0 ]]; then
    err "$(t svc_root_blocked)"
    exit 1
fi

if ! command -v systemctl &>/dev/null; then
    info "$(t svc_no_systemd)"
else
    # Build the service file content from scratch — no source file needed
    NODE_BIN="$(command -v node)"
    write_service() {
        local dest="$1"
        cat > "$dest" << UNIT
[Unit]
Description=ManyBot - WhatsApp Bot
After=network.target

[Service]
Type=simple
WorkingDirectory=$SCRIPT_DIR
ExecStart=$NODE_BIN $SCRIPT_DIR/src/main.js
Restart=on-failure
RestartSec=10
Environment=NODE_ENV=production
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
UNIT
    }

    read -r -p "       $(t svc_prompt)" svc_choice
    svc_choice="${svc_choice,,}"
    OPT_USER="$(t svc_opt_user)"
    OPT_LOCAL="$(t svc_opt_local)"

    if [[ "$svc_choice" == "$OPT_USER" || -z "$svc_choice" ]]; then
        USER_SYSTEMD_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
        mkdir -p "$USER_SYSTEMD_DIR"
        write_service "$USER_SYSTEMD_DIR/manybot.service"
        systemctl --user daemon-reload
        systemctl --user enable --now manybot
        loginctl enable-linger "$(id -un)" 2>/dev/null || warn "$(t svc_no_linger)"
        ok "$(t svc_user_done)"
        info "$(t svc_user_cmds)"
    elif [[ "$svc_choice" == "$OPT_LOCAL" ]]; then
        write_service "$SCRIPT_DIR/manybot.service"
        ok "$(t svc_local_done)"
        info "$(t svc_local_hint)"
    else
        info "$(t svc_skipped)"
    fi
fi

# ── Done ──────────────────────────────────────────────────────────────────────
printf "\n  ${GREEN}${BOLD}$(t done)${R}\n\n"
