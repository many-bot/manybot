#!/bin/bash
set -euo pipefail

LATEST_URL="https://git.stxerr.dev/manybot.git/plain/latest"
DOWNLOAD_BASE="https://git.stxerr.dev/manybot.git/snapshot"

SCRIPT_PATH="$(realpath "$0")"
INSTALL_DIR="$(dirname "$SCRIPT_PATH")"

TMP_DIR="$(mktemp -d)"
trap 'rm -rf "$TMP_DIR"' EXIT

if [[ "${1:-}" == "--apply-update" ]]; then
    INSTALL_DIR="$2"
    NEW_DIR="$3"
    BACKUP_DIR="$4"

    OLD_DIR="${INSTALL_DIR}.old"

    echo
    echo "[7/9] Replacing installation..."

    rm -rf "$OLD_DIR"

    mv "$INSTALL_DIR" "$OLD_DIR"
    mv "$NEW_DIR" "$INSTALL_DIR"

    echo
    echo "[8/9] Restoring persistent files..."

    BACKUP_ITEMS=(
        "manybot.conf"
        ".wwebjs_auth"
        ".wwebjs_cache"
        "src/plugins"
    )

    for item in "${BACKUP_ITEMS[@]}"; do
        SRC="$BACKUP_DIR/$item"
        DST="$INSTALL_DIR/$item"

        if [[ -e "$SRC" ]]; then
            rm -rf "$DST"

            mkdir -p "$(dirname "$DST")"
            cp -a "$SRC" "$DST"

            echo "  restored: $item"
        fi
    done

    echo
    echo "[9/9] Fixing permissions..."

    chown -R "$(id -u):$(id -g)" "$INSTALL_DIR" 2>/dev/null || true

    rm -rf "$OLD_DIR"

    echo
    echo "ManyBot updated successfully."
    echo "Run: node src/main.js"

    exit 0
fi

echo "[1/9] Fetching latest version..."

VERSION="$(curl -fsSL "$LATEST_URL" | tr -d '\n')"

[[ -n "$VERSION" ]]

echo "Latest version: $VERSION"

ARCHIVE="manybot-${VERSION}.zip"
URL="${DOWNLOAD_BASE}/${ARCHIVE}"

echo
echo "[2/9] Downloading release..."

curl -fL "$URL" -o "$TMP_DIR/$ARCHIVE"

echo
echo "[3/9] Extracting release..."

mkdir "$TMP_DIR/extract"

unzip -q "$TMP_DIR/$ARCHIVE" -d "$TMP_DIR/extract"

EXTRACT_DIR="$(find "$TMP_DIR/extract" -mindepth 1 -maxdepth 1 -type d | head -n1)"

[[ -n "$EXTRACT_DIR" ]]
[[ -f "$EXTRACT_DIR/package.json" ]]

echo
echo "[4/9] Building runtime package..."

RUNTIME_DIR="$TMP_DIR/runtime"

mkdir "$RUNTIME_DIR"

cp -a "$EXTRACT_DIR/src" "$RUNTIME_DIR/"
cp -a "$EXTRACT_DIR/package.json" "$RUNTIME_DIR/"
cp -a "$EXTRACT_DIR/package-lock.json" "$RUNTIME_DIR/"
cp -a "$EXTRACT_DIR/README.md" "$RUNTIME_DIR/"
cp -a "$EXTRACT_DIR/update" "$RUNTIME_DIR/"

if [[ -f "$EXTRACT_DIR/manybot.conf.example" ]]; then
    cp -a "$EXTRACT_DIR/manybot.conf.example" "$RUNTIME_DIR/"
fi

echo
echo "[5/9] Backing up persistent files..."

BACKUP_DIR="$TMP_DIR/backup"
mkdir "$BACKUP_DIR"

BACKUP_ITEMS=(
    "manybot.conf"
    ".wwebjs_auth"
    ".wwebjs_cache"
    "src/plugins"
)

for item in "${BACKUP_ITEMS[@]}"; do
    SRC="$INSTALL_DIR/$item"

    if [[ -e "$SRC" ]]; then
        mkdir -p "$BACKUP_DIR/$(dirname "$item")"
        cp -a "$SRC" "$BACKUP_DIR/$item"

        echo "  backed up: $item"
    fi
done

echo
echo "[6/9] Moving updater to temporary execution..."

TMP_SCRIPT="$TMP_DIR/update-runtime.sh"

cp "$SCRIPT_PATH" "$TMP_SCRIPT"
chmod +x "$TMP_SCRIPT"

exec "$TMP_SCRIPT" \
    --apply-update \
    "$INSTALL_DIR" \
    "$RUNTIME_DIR" \
    "$BACKUP_DIR"
