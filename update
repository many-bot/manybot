#!/bin/bash
set -euo pipefail

LATEST_URL="https://git.stxerr.dev/manybot.git/plain/latest"
DOWNLOAD_BASE="https://git.stxerr.dev/manybot.git/snapshot"

SCRIPT_PATH="$(realpath "$0")"
SCRIPT_DIR="$(dirname "$SCRIPT_PATH")"

TMP_DIR="$(mktemp -d)"
WORK_DIR="$TMP_DIR/work"
BACKUP_DIR="$TMP_DIR/backup"

if [[ "${1:-}" == "--internal-run" ]]; then
    SCRIPT_DIR="$2"
    EXTRACT_DIR="$3"
    BACKUP_DIR="$4"

    echo
    echo "[7/8] Replacing old installation..."

    find "$SCRIPT_DIR" \
        -mindepth 1 \
        ! -name "$(basename "$0")" \
        -exec rm -rf {} +

    cp -a "$EXTRACT_DIR"/. "$SCRIPT_DIR/"

    echo
    echo "[8/8] Restoring persistent files..."

    BACKUP_ITEMS=(
        "manybot.conf"
        ".wwebjs_auth"
        ".wwebjs_cache"
        "src/plugins"
    )

    for item in "${BACKUP_ITEMS[@]}"; do
        SRC="$BACKUP_DIR/$item"

        if [[ -e "$SRC" ]]; then
            mkdir -p "$SCRIPT_DIR/$(dirname "$item")"
            cp -a "$SRC" "$SCRIPT_DIR/$item"

            echo "  restored: $item"
        fi
    done

    echo
    echo "ManyBot updated successfully."
    echo "Run: node src/main.js"

    exit 0
fi

cleanup() {
    rm -rf "$TMP_DIR"
}
trap cleanup EXIT

mkdir -p "$WORK_DIR"
mkdir -p "$BACKUP_DIR"

echo "[1/8] Fetching latest version..."

VERSION="$(curl -fsSL "$LATEST_URL" | tr -d '\n')"

[[ -n "$VERSION" ]]

ARCHIVE="manybot-${VERSION}.zip"
URL="${DOWNLOAD_BASE}/${ARCHIVE}"

echo "Latest version: $VERSION"

echo
echo "[2/8] Downloading release..."

curl -fL "$URL" -o "$TMP_DIR/$ARCHIVE"

echo
echo "[3/8] Extracting release..."

unzip -q "$TMP_DIR/$ARCHIVE" -d "$WORK_DIR"

echo
echo "[4/8] Locating extracted directory..."

EXTRACT_DIR="$(find "$WORK_DIR" -mindepth 1 -maxdepth 1 -type d | head -n1)"

[[ -n "$EXTRACT_DIR" ]]
[[ -f "$EXTRACT_DIR/package.json" ]]

echo
echo "[5/8] Backing up persistent files..."

BACKUP_ITEMS=(
    "manybot.conf"
    ".wwebjs_auth"
    ".wwebjs_cache"
    "src/plugins"
)

for item in "${BACKUP_ITEMS[@]}"; do
    SRC="$SCRIPT_DIR/$item"

    if [[ -e "$SRC" ]]; then
        mkdir -p "$BACKUP_DIR/$(dirname "$item")"
        cp -a "$SRC" "$BACKUP_DIR/$item"

        echo "  backed up: $item"
    fi
done

echo
echo "[6/8] Moving updater to temporary execution..."

TMP_SCRIPT="$TMP_DIR/update-runtime.sh"
cp "$SCRIPT_PATH" "$TMP_SCRIPT"
chmod +x "$TMP_SCRIPT"

exec "$TMP_SCRIPT" --internal-run \
    "$SCRIPT_DIR" \
    "$EXTRACT_DIR" \
    "$BACKUP_DIR"
