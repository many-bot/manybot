[Unit]
Description=ManyBot - WhatsApp Bot
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/manybot
ExecStart=/usr/bin/node /opt/manybot/src/main.js
Restart=on-failure
RestartSec=10
Environment=NODE_ENV=production

# Logs via journalctl
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
